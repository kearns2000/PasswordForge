{
  "PasswordForge": {
    "Policies": {
      "CustomerPassword": {
        "MinLength": 16,
        "MaxLength": 64,
        "RequireUppercase": true,
        "RequireLowercase": true,
        "RequireDigit": true,
        "RequireSymbol": true,
        "AllowedSymbols": "@#$%!",
        "AvoidAmbiguousCharacters": true
      },
      "TemporaryPassword": {
        "MinLength": 20,
        "MaxLength": 32,
        "RequireUppercase": true,
        "RequireLowercase": true,
        "RequireDigit": true,
        "RequireSymbol": true
      }
    }
  }
}
